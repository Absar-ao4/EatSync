<resources>

    <style name="Theme.EatSync" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#FFF7ED</item>
        <item name="android:navigationBarColor">#FFF7ED</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="Theme.EatSync.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FC8019</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/eatsync_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">#FC8019</item>
        <item name="postSplashScreenTheme">@style/Theme.EatSync</item>
    </style>

</resources>